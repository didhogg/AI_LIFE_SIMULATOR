# AOHP 调试控制台 · 浏览器 LLM 配置
# 复制为 .env，填入真实密钥
# ⚠ .env 已加入 .gitignore——绝不提交真 key
# ⚠ 修改 .env 后须重启 npm run dev（Vite 仅启动时读 .env）

# DeepSeek API 密钥（必填·浏览器 llmDemo 模式使用）
# vite.config.ts 将其注入为 process.env.DEEPSEEK_API_KEY
VITE_DEEPSEEK_API_KEY=sk-xxxx

# 可选：覆盖 API 端点（默认 https://api.deepseek.com）
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：覆盖模型名（默认 deepseek-chat）
VITE_DEEPSEEK_MODEL=deepseek-chat

# 可选：采样温度 0-2（默认 0.9·叙事多样性用高温）
VITE_DEEPSEEK_TEMPERATURE=0.9

# 可选：调试开关·打印发给 LLM 的原始 prompt（1=开）
VITE_DUMP_PROMPT=0
